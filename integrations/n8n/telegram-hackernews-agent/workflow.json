        "jsCode": "const message = $input.first().json.message;\nconst hasAudio = message.voice;\nreturn [{ json: { hasAudio: !!hasAudio, messageType: hasAudio ? \"audio\" : \"text\", text: message.text || \"\", audioFileId: hasAudio ? (message.voice?.file_id) : null, chatId: message.chat.id } }];"
