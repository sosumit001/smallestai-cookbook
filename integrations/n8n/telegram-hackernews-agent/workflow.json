    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output[0].content[0].text;\n\nconst clean = raw\n  .replace(/\\[([^\\]]+)\\]\\([^\\)]+\\)/g, '$1')\n  .replace(/🔥|⬆️|📈|✅|❌|👆/g, '')\n  .replace(/\\\\n/g, '. ')\n  .replace(/\\n/g, '. ')\n  .replace(/—/g, ',')\n  .replace(/\\*/g, '')\n  .replace(/#+\\s/g, '')\n  .replace(/\\s{2,}/g, ' ')\n  .trim();\n\nreturn [{ json: { cleanText: clean } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
