{
  "expo": {
    "name": "MyClinic",
    "slug": "atoms-voice-widget",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "myclinic",
    "ios": {
      "bundleIdentifier": "ai.smallest.atoms.voicewidget",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MyClinic uses your microphone so you can ask the assistant questions by voice.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "ai.smallest.atoms.voicewidget",
      "adaptiveIcon": {
        "backgroundColor": "#FBFAF5"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "react-native-permissions",
        { "iosPermissions": ["Microphone"] }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
