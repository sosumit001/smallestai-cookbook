# Smallest AI API Key - get yours at https://smallest.ai/console
SMALLEST_API_KEY=your-smallest-api-key-here
SMALLEST_API_BASE_URL=https://api.smallest.ai
SMALLEST_RECEPTIONIST_AGENT_ID=your-agent-id-after-setup

# Google Calendar - service account from GCP JSON
GCP_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCP_PROJECT_ID=your-gcp-project-id
GCP_SUBJECT_EMAIL=you@example.com
GCP_IMPERSONATE=false

# Optional
PORT=4000
PUBLIC_WEBHOOK_BASE_URL=https://your-ngrok-url
CALENDAR_TIMEZONE=America/Los_Angeles

# Optional - confirmation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM="Calendar Receptionist <your-email@example.com>"

# Client (client/.env)
VITE_SMALLEST_ASSISTANT_ID=your-agent-id-after-setup
